# Wahaku Environment Configuration
# Copy this file to /etc/systemd/system/wahaku.env and update values

# Application Environment
APP_ENV=production
APP_PORT=4500

# Database Configuration (optional - only if using external DB)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=wahaku
# DB_PASSWORD=your_db_password
# DB_NAME=wahaku

# AI Provider Configuration
ACTIVE_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative providers (uncomment if using):
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_BASE_URL=https://api.openai.com/v1

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# CORS Settings (allowed origins for frontend)
CORS_ALLOW_ORIGINS=https://chat.yaakhi.id,https://www.yaakhi.id

# Optional: Google Sheets integration
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
